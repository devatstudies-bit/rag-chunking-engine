# ═══════════════════════════════════════════════════════════════════════════════
# CHUNKING ENGINE — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Provider Selection ────────────────────────────────────────────────────────
# Options: "azure_openai" | "bedrock"
LLM_PROVIDER=azure_openai

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=                                  # optional, for assumed roles
BEDROCK_CHAT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── Milvus Vector Database ────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=document_chunks
MILVUS_EMBEDDING_DIM=1536                           # 1536 for ada-002 / Titan v2

# ── Chunking Defaults ─────────────────────────────────────────────────────────
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
SEMANTIC_BREAKPOINT_THRESHOLD=85                    # percentile for topic shift

# ── API Configuration ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-secret-api-key                         # header: X-API-Key
LOG_LEVEL=INFO
